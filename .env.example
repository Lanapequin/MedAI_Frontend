# MedAI Frontend — Environment Configuration
# Copy this file to .env.local and adjust values for your environment.

# URL of the MedAI backend API.
# Local development:  http://localhost:8000
# Docker Compose:     http://localhost:8000
# Production (AWS):   https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# API mode:
# false → call the real backend (default)
# true  → use client-side simulation (no backend required, for UI demos)
NEXT_PUBLIC_USE_MOCK_API=false
